# Configurações da aplicação
APP_NAME=Nome do Projeto
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=sua-chave-secreta-aqui-mude-em-producao

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nome_do_projeto
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
DATABASE_URL=postgresql://postgres:postgres_password@localhost:5432/nome_do_projeto

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=nome_do_projeto_mongo
MONGO_USER=mongo_user
MONGO_PASSWORD=mongo_password
MONGO_URL=mongodb://mongo_user:mongo_password@localhost:27017/nome_do_projeto_mongo

# JWT
JWT_SECRET_KEY=jwt-secret-key-mude-em-producao
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Configurações de ambiente
ENVIRONMENT=development